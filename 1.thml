<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>女 | 女性历史数字平台</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700;900&family=Noto+Sans+SC:wght@300;400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.min.js"></script>
  <style>
    :root {
      --bg: #0f0f0f;
      --bg-card: #1a1a1a;
      --bg-elevated: #252525;
      --fg: #f0ebe3;
      --fg-muted: #a09890;
      --accent: #c9a06c;
      --accent-dim: #8b7355;
      --border: #3a3a3a;
      --highlight: rgba(201, 160, 108, 0.15);
    }

    * {
      scrollbar-width: thin;
      scrollbar-color: var(--accent-dim) transparent;
    }

    ::-webkit-scrollbar {
      width: 6px;
    }
    ::-webkit-scrollbar-track {
      background: transparent;
    }
    ::-webkit-scrollbar-thumb {
      background: var(--accent-dim);
      border-radius: 3px;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Noto Sans SC', sans-serif;
      background: var(--bg);
      color: var(--fg);
      line-height: 1.8;
    }

    .font-serif {
      font-family: 'Noto Serif SC', serif;
    }

    /* 页面切换动画 */
    .page {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.4s ease, transform 0.4s ease;
    }
    .page.active {
      opacity: 1;
      transform: translateY(0);
    }

    /* 英雄区动画 */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-up {
      animation: fadeUp 0.6s ease forwards;
    }
    .delay-1 { animation-delay: 0.1s; }
    .delay-2 { animation-delay: 0.2s; }
    .delay-3 { animation-delay: 0.3s; }
    .delay-4 { animation-delay: 0.4s; }
    .delay-5 { animation-delay: 0.5s; }

    /* 脚注高亮 */
    .footnote {
      color: var(--accent);
      cursor: pointer;
      transition: color 0.2s;
    }
    .footnote:hover {
      color: #e8c078;
    }
    .footnote.active {
      background: var(--highlight);
      border-radius: 2px;
    }

    /* 参考文献高亮 */
    .reference-item {
      transition: background 0.3s, border-color 0.3s;
    }
    .reference-item.active {
      background: var(--highlight);
      border-left-color: var(--accent);
    }

    /* 卡片悬浮 */
    .person-card {
      transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    }
    .person-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 24px rgba(0,0,0,0.4);
      border-color: var(--accent-dim);
    }

    /* 标签样式 */
    .tag {
      background: var(--bg-elevated);
      border: 1px solid var(--border);
      transition: all 0.2s;
    }
    .tag:hover {
      border-color: var(--accent-dim);
      color: var(--accent);
    }

    /* 导航下划线 */
    .nav-link {
      position: relative;
    }
    .nav-link::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 50%;
      width: 0;
      height: 2px;
      background: var(--accent);
      transition: width 0.3s, left 0.3s;
    }
    .nav-link:hover::after,
    .nav-link.active::after {
      width: 100%;
      left: 0;
    }

    /* 统计数字动画 */
    @keyframes countUp {
      from { opacity: 0; transform: scale(0.8); }
      to { opacity: 1; transform: scale(1); }
    }
    .stat-number {
      animation: countUp 0.5s ease forwards;
    }

    /* 减少动画 */
    @
